# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/company-profile

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# Email Configuration (for contact forms)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@company.com

# File Upload Configuration
MAX_FILE_SIZE=5000000
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-this-in-production

# Admin Configuration
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=admin123

# Company Information
COMPANY_NAME=Your Company Name
COMPANY_EMAIL=info@company.com
COMPANY_PHONE=+1-234-567-8900
COMPANY_ADDRESS=123 Business St, City, State 12345

# Social Media
SOCIAL_FACEBOOK=https://facebook.com/yourcompany
SOCIAL_TWITTER=https://twitter.com/yourcompany
SOCIAL_LINKEDIN=https://linkedin.com/company/yourcompany
SOCIAL_INSTAGRAM=https://instagram.com/yourcompany